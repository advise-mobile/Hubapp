# Bundle artifact
*.jsbundle
**/index.android.bundle

# Android drawables copied from node_modules (libs load assets via Metro)
android/app/src/main/res/drawable-*/node_modules_*

# Firebase / Google Services (usar google-services.json.example como modelo)
android/app/google-services.json

# iOS: cópia duplicada do src/ da raiz (Metro usa o src da raiz do projeto)
ios/src/

# Ruby / CocoaPods
**/Pods/
vendor/
/vendor/bundle/

# Temporary files created by Metro to check the health of the file watcher
.metro-health-check*

