# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'HubApp' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  # OneSignal
  pod 'react-native-onesignal', :path => '../node_modules/react-native-onesignal'

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Garantir NODE_BINARY para o Xcode (script phases não herdam PATH do terminal)
    ios_dir = File.dirname(installer.sandbox.root)
    xcode_env_local = File.join(ios_dir, '.xcode.env.local')
    node_path = Pod::Executable.execute_command('node', ['-e', 'console.log(process.execPath)']).strip
    if node_path && File.exist?(node_path)
      File.write(xcode_env_local, "export NODE_BINARY=#{node_path}\n")
      Pod::UI.puts "Wrote NODE_BINARY=#{node_path} to #{xcode_env_local}".green
    else
      Pod::UI.warn "Could not detect node path. Create ios/.xcode.env.local with: export NODE_BINARY=$(which node)"
    end

    # Deployment target mínimo (evita erro "9.0 not in range 12.0 to 26.2")
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.1'
      end
    end

    # Hermes script phase: REACT_NATIVE_PATH (Pods fica em ios/Pods, node_modules na raiz do projeto)
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['REACT_NATIVE_PATH'] = '${PODS_ROOT}/../../node_modules/react-native'
      end
    end
  end
end
